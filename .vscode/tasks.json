{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "nanoGPT: prepare Shakespeare data",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "data/shakespeare_char/prepare.py"
      ],
      "options": {
        "cwd": "${workspaceFolder}/nanoGPT"
      },
      "problemMatcher": []
    },
    {
      "label": "nanoGPT: quick train Shakespeare",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "train.py",
        "config/train_shakespeare_char.py",
        "--device=mps",
        "--compile=False",
        "--eval_iters=5",
        "--eval_interval=10",
        "--log_interval=1",
        "--block_size=32",
        "--batch_size=4",
        "--n_layer=2",
        "--n_head=2",
        "--n_embd=64",
        "--max_iters=20",
        "--lr_decay_iters=20",
        "--warmup_iters=1",
        "--dropout=0.0",
        "--always_save_checkpoint=True"
      ],
      "options": {
        "cwd": "${workspaceFolder}/nanoGPT"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "nanoGPT: sample Shakespeare",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "sample.py",
        "--out_dir=out-shakespeare-char",
        "--device=mps",
        "--compile=False",
        "--max_new_tokens=120",
        "--num_samples=1"
      ],
      "options": {
        "cwd": "${workspaceFolder}/nanoGPT"
      },
      "problemMatcher": []
    }
  ]
}
